{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "sourceMap": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
   "types": ["node", "express", "pg", "vitest/globals"]
  },
 "include": ["src", "tests"],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "src/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/sdk/grpc"
  ]
}
